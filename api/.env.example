# Copier ce fichier en .env et renseigner la vraie valeur.
# Le .env n'est JAMAIS commite (voir .gitignore).

# Connexion PostgreSQL / Supabase.
# Local   : postgresql://postgres:MOT_DE_PASSE@localhost:5434/tourisme_train
# Supabase: postgresql://postgres.tqzvujolklzcaytvaajo:MOT_DE_PASSE@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:00000@localhost:5434/tourisme_train

# Origines autorisees pour le front (separees par des virgules).
# En prod, mettre l'URL Vercel/Netlify du front.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
